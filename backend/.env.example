# Backend Environment Variables Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# ==================== DATABASE ====================
# MongoDB connection string
# Local development: mongodb://127.0.0.1:27017/employee
# Production (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/employee?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/employee

# ==================== AUTHENTICATION ====================
# JWT Secret Key - MUST be a strong, random string in production
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# JWT Expiration (default: 1d)
JWT_EXPIRES_IN=1d

# ==================== SERVER ====================
# Server port
PORT=3001

# Node environment (development, production, test)
NODE_ENV=development

# ==================== FRONTEND ====================
# Frontend URL for CORS (adjust based on your frontend port)
FRONTEND_URL=http://localhost:5173

# ==================== OPTIONAL ====================
# Logging level (info, warn, error, debug)
LOG_LEVEL=info

# Enable debug mode
DEBUG=false

# ==================== EMAIL (Future Implementation) ====================
# SMTP Configuration for email notifications
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@mindwell.com

# ==================== REDIS (Future Implementation) ====================
# Redis URL for caching
# REDIS_URL=redis://localhost:6379

# ==================== SENTRY (Future Implementation) ====================
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==================== CLOUDINARY (Future Implementation) ====================
# Cloudinary credentials for image/file storage
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ==================== PAYMENT (Future Implementation) ====================
# Stripe API keys
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ==================== NOTES ====================
# 
# Security Best Practices:
# 1. Never commit .env files to version control
# 2. Use strong, random values for JWT_SECRET (minimum 32 characters)
# 3. Rotate secrets regularly (every 90 days)
# 4. Use different values for development, staging, and production
# 5. Store production secrets in secure vaults (not in code)
#
# To generate a secure JWT secret, run:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Example secure JWT_SECRET:
# JWT_SECRET=7f9a2b4c8d1e3f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9
