# Frontend Environment Variables Configuration
# Copy this file to .env.production for production builds
# or .env.local for local development overrides

# ==================== API CONFIGURATION ====================
# Backend API URL
# Development: http://localhost:3001
# Production: https://your-backend-domain.com
VITE_API_URL=http://localhost:3001

# ==================== OPTIONAL CONFIGURATION ====================

# Enable debug mode (useful for development)
# VITE_DEBUG=true

# Google Analytics ID (future implementation)
# VITE_GA_ID=G-XXXXXXXXXX

# Sentry DSN for frontend error tracking (future implementation)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Feature flags (future implementation)
# VITE_ENABLE_CHAT=true
# VITE_ENABLE_VIDEO_CALLS=false
# VITE_ENABLE_PAYMENTS=false

# ==================== BUILD CONFIGURATION ====================

# Build environment
# VITE_NODE_ENV=production

# ==================== NOTES ====================
#
# Important:
# 1. In Vite, environment variables must be prefixed with VITE_
#    to be exposed to the browser
#
# 2. Never put sensitive secrets here (like API keys that should
#    remain private) as these will be exposed in the client bundle
#
# 3. Create separate env files for different environments:
#    - .env.local         (local development, git-ignored)
#    - .env.development   (development environment)
#    - .env.production    (production environment)
#
# 4. Access these variables in your code using:
#    import.meta.env.VITE_API_URL
#
# Example usage in code:
# const API_URL = import.meta.env.VITE_API_URL || 'http://localhost:3001';
#
# For production deployment:
# 1. Set VITE_API_URL to your production backend URL
# 2. Run: npm run build
# 3. Deploy the 'dist' folder
